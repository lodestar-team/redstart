# Template rendered by .github/workflows/release.yml on each tagged release.
# The placeholders (__VERSION__, __SHA_*__) are substituted with the real
# version and per-platform sha256 checksums, then committed to the tap repo as
# Formula/redstart.rb. Edit the template here, never the rendered formula.
class Redstart < Formula
  desc "Multi-file language for authoring The Graph subgraphs"
  homepage "https://github.com/lodestar-team/redstart"
  version "__VERSION__"
  license "MIT"

  on_macos do
    on_arm do
      url "__BASE__/redstart-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_MAC_ARM__"
    end
    on_intel do
      url "__BASE__/redstart-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_MAC_X86__"
    end
  end

  on_linux do
    on_arm do
      url "__BASE__/redstart-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_ARM__"
    end
    on_intel do
      url "__BASE__/redstart-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_X86__"
    end
  end

  def install
    bin.install "redstart"
  end

  test do
    assert_match "redstart #{version}", shell_output("#{bin}/redstart --version")
  end
end
