// Generated by Redstart — do not edit by hand.
// Eject freely: this is the AssemblyScript a careful human would write.

import { BigInt, DataSourceContext, ethereum, log } from "@graphprotocol/graph-ts"
import { PoolCreated as PoolCreatedEvent } from "../generated/FactoryContract/Factory"
import { Swap as SwapEvent, SwapCall } from "../generated/templates/PoolTemplate/Pool"
import { PoolTemplate } from "../generated/templates"
import { Pair, Snapshot, Swap } from "../generated/schema"

export function handlePoolCreated(event: PoolCreatedEvent): void {
  let pair = new Pair(event.params.pool)
  pair.swapCount = BigInt.zero()
  let ctx = new DataSourceContext()
  ctx.setBytes("token0", event.params.token0)
  PoolTemplate.createWithContext(event.params.pool, ctx)

  pair.save()
}

export function handleSwap(event: SwapEvent): void {
  let pair = Pair.load(event.address)
  if (pair == null) {
    pair = new Pair(event.address)
    pair.swapCount = BigInt.zero()
  }
  let s = new Swap(event.transaction.hash.concatI32(event.logIndex.toI32()))
  s.side = "Buy"
  s.amount = event.params.amount0
  if (event.params.amount0.gt(BigInt.zero())) {
    s.side = "Sell"
  }
  for (let i = 0; i < 3; i++) {
    pair.swapCount = pair.swapCount.plus(BigInt.fromI32(1))
  }

  pair.save()
  s.save()
}

export function handleSwapCall(call: SwapCall): void {
  log.info("swap routed to {}", [call.inputs.to.toHexString()])
}

export function handlePoolTemplateBlock(block: ethereum.Block): void {
  let snap = new Snapshot(block.hash)
  snap.total = block.number

  snap.save()
}
