function getOrCreateDelegation(indexerId: Bytes, delegator: Bytes, ts: BigInt): Delegation {
  let id = indexerId.toHexString() + "-" + delegator.toHexString()
  let delegation = Delegation.load(id)
  if (delegation == null) {
    delegation = new Delegation(id)
    delegation.indexer = indexerId
    delegation.delegator = delegator
    delegation.tokens = BigInt.zero()
    delegation.shares = BigInt.zero()
    delegation.lockedTokens = BigInt.zero()
    delegation.lockedUntil = BigInt.zero()
    delegation.createdAt = ts
    delegation.lastUpdatedAt = ts
  }
  delegation.save()
  return delegation
}

function getOrCreateGlobalStats(): GlobalStats {
  let stats = GlobalStats.load("global")
  if (stats == null) {
    stats = new GlobalStats("global")
    stats.totalIndexers = 0
    stats.totalOperators = 0
    stats.totalAllocations = 0
    stats.totalActiveAllocations = 0
    stats.totalRewardsDistributed = BigInt.zero()
    stats.totalQueryFeesCollected = BigInt.zero()
  }
  stats.save()
  return stats
}

function getOrCreateIndexer(addr: Bytes): Indexer {
  let existing = Indexer.load(addr)
  if (existing != null) {
    let found = existing!
    return found
  } else {
    let indexer = new Indexer(addr)
    indexer.totalStaked = BigInt.zero()
    indexer.totalDelegated = BigInt.zero()
    indexer.totalRewardsEarned = BigInt.zero()
    indexer.totalQueryFeesCollected = BigInt.zero()
    indexer.allocationCount = 0
    indexer.activeAllocationCount = 0
    indexer.registeredAt = BigInt.zero()
    let stats = getOrCreateGlobalStats()
    stats.totalIndexers = stats.totalIndexers + 1
    indexer.save()
    stats.save()
    return indexer
  }
}

export function handleStakeDelegated(event: StakeDelegatedEvent): void {
  let indexer = getOrCreateIndexer(event.params.indexer)
  let delegation = getOrCreateDelegation(event.params.indexer, event.params.delegator, event.block.timestamp)
  delegation.tokens = delegation.tokens.plus(event.params.tokens)
  delegation.shares = delegation.shares.plus(event.params.shares)
  delegation.lastUpdatedAt = event.block.timestamp
  indexer.totalDelegated = indexer.totalDelegated.plus(event.params.tokens)
  let ts = new DelegationData(event.block.timestamp.toI64())
  ts.timestamp = event.block.timestamp.toI64()
  ts.indexer = event.params.indexer
  ts.delegator = event.params.delegator
  ts.tokens = event.params.tokens
  ts.eventType = "delegated"

  delegation.save()
  indexer.save()
  ts.save()
}

export function handleStakeDelegatedLocked(event: StakeDelegatedLockedEvent): void {
  let indexer = getOrCreateIndexer(event.params.indexer)
  let delegation = getOrCreateDelegation(event.params.indexer, event.params.delegator, event.block.timestamp)
  delegation.lockedTokens = delegation.lockedTokens.plus(event.params.tokens)
