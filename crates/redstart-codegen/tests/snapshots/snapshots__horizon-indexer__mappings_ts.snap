export function handleStakeDelegatedWithdrawn(event: StakeDelegatedWithdrawnEvent): void {
  let indexer = getOrCreateIndexer(event.params.indexer)
  let delegation = getOrCreateDelegation(event.params.indexer, event.params.delegator, event.block.timestamp)
  delegation.tokens = delegation.tokens.minus(event.params.tokens)
  delegation.lockedTokens = BigInt.zero()
  delegation.lastUpdatedAt = event.block.timestamp
  indexer.totalDelegated = indexer.totalDelegated.minus(event.params.tokens)
  let ts = new DelegationData(event.block.timestamp.toI64())
  ts.timestamp = event.block.timestamp.toI64()
  ts.indexer = event.params.indexer
  ts.delegator = event.params.delegator
  ts.tokens = event.params.tokens
  ts.eventType = "withdrawn"

  delegation.save()
