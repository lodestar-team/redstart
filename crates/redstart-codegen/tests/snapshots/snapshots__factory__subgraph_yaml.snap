# Generated by Redstart — do not edit by hand.
specVersion: 1.0.0
description: Factory + pair-template subgraph exercising every handler kind, control flow, and enums.
# subgraph: factory
schema:
  file: ./schema.graphql
dataSources:
  - kind: ethereum
    name: FactoryContract
    network: mainnet
    source:
      address: "0x1F98431c8aD98523631AE4a59f267346ea31F984"
      abi: Factory
      startBlock: 1
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.9
      language: wasm/assemblyscript
      entities:
        - Pair
        - Swap
        - Snapshot
      abis:
        - name: Factory
          file: ./abis/Factory.json
      eventHandlers:
        - event: PoolCreated(indexed address,indexed address,address)
          handler: handlePoolCreated
      file: ./src/mappings.ts
templates:
  - kind: ethereum
    name: PoolTemplate
    network: mainnet
    source:
      abi: Pool
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.9
      language: wasm/assemblyscript
      entities:
        - Pair
        - Swap
        - Snapshot
      abis:
        - name: Pool
          file: ./abis/Pool.json
      eventHandlers:
        - event: Swap(uint256,uint256,indexed address)
          handler: handleSwap
      callHandlers:
        - function: swap(uint256,uint256,address)
          handler: handleSwapCall
      blockHandlers:
        - handler: handlePoolTemplateBlock
          filter:
            kind: polling
            every: 1000
      file: ./src/mappings.ts
